# NMJ Dashboard — Environment Configuration
# Copy this file to .env.local and fill in your values

# Frontend (Next.js) — Port 4000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Backend (Express) — Port 3001
PORT=3001

# AI Provider API Keys (optional — can also be configured via UI)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Database
DATABASE_PATH=./data/nmj.db
