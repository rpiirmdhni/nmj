{
  "name": "nmj-backend",
  "version": "0.1.0",
  "description": "NMJ Dashboard — Express backend with WebSocket, SQLite, and multi-provider AI agent runtime support",
  "main": "src/server.ts",
  "scripts": {
    "dev": "npx tsx src/server.ts",
    "db:seed": "npx tsx src/database.ts",
    "typecheck": "tsc --noEmit"
  },
